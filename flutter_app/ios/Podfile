# Uncomment this line to define a global platform for this project
# iOS 16 is required by flutter_gemma (MediaPipe GenAI / LiteRT-LM engines).
platform :ios, '16.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  # flutter_gemma requires statically linked pods (its LiteRT-LM frameworks
  # are bundled via Native Assets, not as dynamic pod frameworks).
  use_frameworks! :linkage => :static

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end

  # wasm_run FFI symbols live in a static library inside WasmRun.xcframework.
  # They are referenced only from Dart via DynamicLibrary.executable(), so the
  # linker strips them unless we force-load the archive explicitly on the
  # application target (not the pod target). The XCFramework has separate
  # device and simulator slices; use Xcode's conditional build settings to
  # pick the right slice at build time. SRCROOT is the ios/ directory, so
  # ../../ walks up to the repo root where vendor/ lives.
  device_slice = '$(SRCROOT)/../../vendor/wasm_run_flutter/ios/Frameworks/WasmRun.xcframework/ios-arm64/libwasm_run_dart.a'
  simulator_slice = '$(SRCROOT)/../../vendor/wasm_run_flutter/ios/Frameworks/WasmRun.xcframework/ios-arm64_x86_64-simulator/libwasm_run_dart.a'
  installer.aggregate_targets.each do |aggregate_target|
    aggregate_target.user_project.targets.each do |target|
      next unless target.name == 'Runner'
      target.build_configurations.each do |config|
        device_ldflags = config.build_settings['OTHER_LDFLAGS[sdk=iphoneos*]'] ||= ['$(inherited)']
        unless Array(device_ldflags).any? { |f| f.include?(device_slice) }
          device_ldflags << '-Wl,-force_load,' + device_slice
        end
        simulator_ldflags = config.build_settings['OTHER_LDFLAGS[sdk=iphonesimulator*]'] ||= ['$(inherited)']
        unless Array(simulator_ldflags).any? { |f| f.include?(simulator_slice) }
          simulator_ldflags << '-Wl,-force_load,' + simulator_slice
        end
      end
    end
  end

  # The vendored WasmRun.xcframework only ships an arm64 simulator slice.
  # Exclude x86_64 simulator everywhere so Debug simulator builds do not try
  # to link a missing slice.
  exclude_x86_64_sim = { 'EXCLUDED_ARCHS[sdk=iphonesimulator*]' => 'x86_64' }

  # iOS 16 floor everywhere (pods + app target) for flutter_gemma.
  installer.pods_project.build_configurations.each do |config|
    config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
    exclude_x86_64_sim.each { |k, v| config.build_settings[k] = v }
  end

  installer.aggregate_targets.each do |aggregate_target|
    aggregate_target.user_project.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
      exclude_x86_64_sim.each { |k, v| config.build_settings[k] = v }
    end
    aggregate_target.user_targets.each do |user_target|
      user_target.build_configurations.each do |config|
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
        exclude_x86_64_sim.each { |k, v| config.build_settings[k] = v }
      end
    end
    aggregate_target.user_project.save
  end
end
