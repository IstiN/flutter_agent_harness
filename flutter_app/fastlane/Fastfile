# Fastfile for the Fa app (flutter_app).
#
# TestFlight submit lanes, adapted 1:1 from learn.ai's deploy setup: builds
# happen in the CI workflows (flutter build ipa / flutter build macos), so
# these lanes only upload the produced artifacts with the App Store Connect
# API key from the environment:
#
#   APP_STORE_CONNECT_KEY_ID / APP_STORE_CONNECT_ISSUER_ID /
#   APP_STORE_CONNECT_KEY_CONTENT
#
# iOS:    IOS_IPA_PATH points at the built .ipa (default: build/ios/*.ipa's
#         conventional location).
# macOS:  MACOS_PKG_PATH points at the signed .pkg (Mac Installer
#         Distribution cert) and MACOS_BUNDLE_ID overrides dev.fa1.app.

def asc_api_key
  app_store_connect_api_key(
    key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
    issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
    key_content: ENV["APP_STORE_CONNECT_KEY_CONTENT"],
    is_key_content_base64: false,
    in_house: false
  )
end

platform :ios do
  desc "Build iOS IPA only (for CI split build/submit pattern)"
  lane :build_only do
    # The CI workflow creates and unlocks build.keychain before calling this lane.
    if File.exist?(File.expand_path("~/Library/Keychains/build.keychain-db"))
      sh("security list-keychains -d user -s #{Dir.home}/Library/Keychains/login.keychain-db #{Dir.home}/Library/Keychains/build.keychain-db")
      sh("security unlock-keychain -p '' #{Dir.home}/Library/Keychains/build.keychain-db")
      sh("security default-keychain -d user -s #{Dir.home}/Library/Keychains/login.keychain-db")
    else
      sh("security list-keychains -d user -s #{Dir.home}/Library/Keychains/login.keychain-db")
    end

    team_id = ENV["IOS_TEAM_ID"] || "YP9HC3USZ3"
    bundle_id = ENV["IOS_BUNDLE_ID"] || "dev.fa1.app"
    profile_name = ENV["IOS_PROVISIONING_PROFILE_NAME"] || "Fa Profile"
    signing_identity = ENV["IOS_SIGNING_IDENTITY"] || "iPhone Distribution"

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/Runner.xcodeproj",
      team_id: team_id,
      bundle_identifier: bundle_id,
      profile_name: profile_name,
      code_sign_identity: signing_identity
    )

    sh("flutter", "clean")
    sh("flutter", "pub", "get")
    cocoapods(podfile: "ios/Podfile")

    if ENV["BUILD_NUMBER"]
      increment_build_number(xcodeproj: "ios/Runner.xcodeproj", build_number: ENV["BUILD_NUMBER"])
    else
      increment_build_number(xcodeproj: "ios/Runner.xcodeproj")
    end

    sh("xcrun simctl list > /dev/null 2>&1 || true")
    sh("xcrun simctl boot 'iPhone 16' 2>/dev/null || xcrun simctl boot 'iPhone 15' 2>/dev/null || true")
    sh("flutter", "build", "ios", "--release", "--no-codesign")

    build_app(
      workspace: "ios/Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      output_directory: "build/ios/ipa",
      output_name: "fa.ipa",
      skip_build_archive: false,
      clean: true,
      sdk: "iphoneos",
      export_options: {
        method: "app-store",
        provisioningProfiles: {
          bundle_id => profile_name
        },
        signingStyle: "manual",
        teamID: team_id,
        manageAppVersionAndBuildNumber: false,
        uploadBitcode: false,
        compileBitcode: false
      },
      export_xcargs: "-allowProvisioningUpdates"
    )
  end

  desc "Upload the built IPA to TestFlight (no metadata/screenshots)"
  lane :submit_only do
    ipa = ENV["IOS_IPA_PATH"] || File.expand_path("../build/ios/ipa/fa.ipa", __dir__)
    UI.user_error!("IPA not found: #{ipa} (set IOS_IPA_PATH)") unless File.exist?(ipa)

    upload_to_testflight(
      api_key: asc_api_key,
      ipa: ipa,
      skip_waiting_for_build_processing: true,
      skip_submission: true,
      distribute_external: false,
      notify_external_testers: false
    )
  end
end

platform :mac do
  desc "Upload the built PKG to TestFlight (no metadata/screenshots)"
  lane :submit_only do
    pkg = ENV["MACOS_PKG_PATH"] || File.expand_path("../build/macos/fa.pkg", __dir__)
    UI.user_error!("PKG not found: #{pkg} (set MACOS_PKG_PATH)") unless File.exist?(pkg)

    upload_to_testflight(
      api_key: asc_api_key,
      pkg: pkg,
      app_identifier: ENV["MACOS_BUNDLE_ID"] || "dev.fa1.app",
      skip_waiting_for_build_processing: true,
      skip_submission: true,
      distribute_external: false,
      notify_external_testers: false
    )
  end
end
