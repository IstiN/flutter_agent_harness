#!/usr/bin/env bash
# install.sh вҖ” non-interactive one-line installer for the Fa CLI
#              (flutter_agent_harness). Works when piped:
#                curl -fsSL https://fa1.dev/install.sh | sh
#
# What it does:
#   1. Detects OS and architecture.
#   2. Downloads the matching Fa binary from the latest GitHub Release.
#   3. Installs it to a directory on your PATH.
#   4. Prints a concise setup recipe and exits.
#
# Fallback: if the binary is unavailable for this platform, the script falls
# back to `dart pub global activate`, which requires the Dart SDK.
#
# For interactive configuration (provider, model, API key), run:
#   curl -fsSL https://fa1.dev/setup.sh | sh
#
# {{GENERATED_HEADER}}

set -euo pipefail

REPO="IstiN/flutter_agent_harness"
BINARY="fa"

# в”Җв”Җ Output helpers в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
say() {
  printf '%s\n' "$*"
}

info() {
  printf '\033[1;34mвҶ’\033[0m %s\n' "$*"
}

ok() {
  printf '\033[1;32mвң”\033[0m %s\n' "$*"
}

warn() {
  printf '\033[1;33m!\033[0m %s\n' "$*" >&2
}

err() {
  printf '\033[1;31mвңҳ\033[0m %s\n' "$*" >&2
}

# в”Җв”Җ Banner в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
say ""
say "  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—       в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—"
say "  в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—      в•ҡв•җв•җв–Ҳв–Ҳв•”в•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘"
say "  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•”в–Ҳв–Ҳв–Ҳв–Ҳв•”в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в–Ҳв–Ҳв•— в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘"
say "  в–Ҳв–Ҳв•”в•җв•җв•қ  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в•ҡв•җв•җв•җв•җв•қ   в–Ҳв–Ҳв•‘   в•ҡв•җв•җв•җв•җв•қ  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘"
say "  в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘         в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘ в•ҡв•җв•қ в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘ в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—"
say "  в•ҡв•җв•қ     в•ҡв•җв•қ  в•ҡв•җв•қ         в•ҡв•җв•қ   в•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•қ     в•ҡв•җв•қв•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қ"
say ""
say "  Fa installer вҖ” flutter_agent_harness CLI"
say ""

# в”Җв”Җ 0. Platform check в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# This script is for Unix-like shells. Native Windows users should use the
# PowerShell installer instead. Git Bash / MSYS / Cygwin can run this script,
# but the PowerShell installer is the recommended Windows path because it
# configures the user PATH and environment variables correctly.
case "${OSTYPE:-}" in
  msys*|cygwin*|mingw*)
    warn "you appear to be running in a Bash emulation layer on Windows."
    say ""
    say "  For the best Windows experience, use the PowerShell installer:"
    say ""
    say "    irm https://fa1.dev/install.ps1 | iex"
    say ""
    exit 0
    ;;
esac

# в”Җв”Җ 1. Detect OS/arch в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
os=""
arch=""
case "$(uname -s)" in
  Linux*)     os=linux ;;
  Darwin*)    os=macos ;;
  *)
    err "unsupported OS: $(uname -s)"
    exit 1
    ;;
esac

case "$(uname -m)" in
  x86_64|amd64)  arch=x64 ;;
  arm64|aarch64) arch=arm64 ;;
  armv7l)        arch=arm ;;
  *)
    err "unsupported architecture: $(uname -m)"
    exit 1
    ;;
esac

asset="fa-${os}-${arch}"

# в”Җв”Җ 2. Resolve install directory в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
install_dir="${FA_INSTALL_DIR:-$HOME/.local/bin}"
# Prefer a directory already on PATH, falling back to ~/.local/bin.
candidates=("$install_dir" "$HOME/.local/bin" "$HOME/bin")
install_dir=""
for candidate in "${candidates[@]}"; do
  if [[ ":${PATH}:" == *:"$candidate":* ]]; then
    install_dir="$candidate"
    break
  fi
done
[[ -z $install_dir ]] && install_dir="$HOME/.local/bin"

mkdir -p "$install_dir"
target="$install_dir/$BINARY"

# в”Җв”Җ 3. Resolve latest release and asset в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
info "Resolving latest release..."
release_json=""
if command -v curl >/dev/null 2>&1; then
  release_json=$(curl -fsSL "https://api.github.com/repos/$REPO/releases/latest" 2>/dev/null || true)
elif command -v wget >/dev/null 2>&1; then
  release_json=$(wget -qO- "https://api.github.com/repos/$REPO/releases/latest" 2>/dev/null || true)
fi

version=""
download_url=""
if [[ -n $release_json ]]; then
  version=$(printf '%s' "$release_json" | grep -o '"tag_name": *"[^"]*"' | head -n1 | sed 's/.*"\([^"]*\)".*/\1/')
  download_url=$(printf '%s' "$release_json" | grep -o '"browser_download_url": *"[^"]*'"$asset"'"' | head -n1 | sed 's/.*"\([^"]*\)".*/\1/')
fi

# в”Җв”Җ 4. Install binary (or fall back to Dart) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
if [[ -n $download_url ]]; then
  info "Downloading Fa $version for ${os}-${arch}..."
  if command -v curl >/dev/null 2>&1; then
    curl -fSL --progress-bar "$download_url" -o "$target"
  else
    wget --show-progress -qO "$target" "$download_url"
  fi
  chmod +x "$target"
  ok "Installed $target"
else
  warn "No prebuilt binary found for ${os}-${arch}. Falling back to Dart pub global activate."
  if ! command -v dart >/dev/null 2>&1; then
    err "the Dart SDK ('dart') is not on your PATH, and no prebuilt binary is available for ${os}-${arch}."
    say ""
    say "  Install Flutter (includes Dart) from:"
    say ""
    say "    https://docs.flutter.dev/get-started/install"
    say ""
    exit 1
  fi
  PACKAGE="flutter_agent_harness"
  PUB_CACHE_BIN="${PUB_CACHE_BIN:-$HOME/.pub-cache/bin}"
  info "Activating $PACKAGE from pub.dev..."
  dart pub global activate "$PACKAGE"
  install_dir="$PUB_CACHE_BIN"
  target="$install_dir/$BINARY"
fi

# в”Җв”Җ 5. Ensure install directory is on PATH в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
if command -v fa >/dev/null 2>&1 || command -v fah >/dev/null 2>&1; then
  ok "'fa' is on PATH ($(command -v fa 2>/dev/null || command -v fah))."
else
  warn "'fa' is not on PATH yet. The executable lives in $install_dir"
  say ""

  shell_rc=""
  case "${SHELL:-}" in
    */zsh)  shell_rc="$HOME/.zshrc" ;;
    */bash) shell_rc="$HOME/.bashrc" ;;
    */fish) shell_rc="$HOME/.config/fish/config.fish" ;;
  esac

  if [[ -n $shell_rc ]]; then
    mkdir -p "$(dirname "$shell_rc")"
    if [[ -f $shell_rc ]] && grep -qF "$install_dir" "$shell_rc" 2>/dev/null; then
      ok "$install_dir is already referenced in $shell_rc"
    else
      printf '\n# Fa CLI PATH\nexport PATH="$PATH:%s"\n' "$install_dir" >> "$shell_rc"
      ok "Added $install_dir to $shell_rc"
    fi
    say ""
    warn "Open a new terminal window/tab, or run this in the current shell:"
    say ""
    printf '    source %s\n' "$shell_rc"
    say ""
    warn "To use 'fa' right now without reloading, run:"
    say ""
    printf '    export PATH="$PATH:%s"\n' "$install_dir"
    say ""
  else
    warn "Add this to your shell startup file (and open a new terminal):"
    say ""
    printf '    export PATH="$PATH:%s"\n' "$install_dir"
    say ""
  fi
fi

# в”Җв”Җ 6. Done в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
say ""
ok "Installation complete."
say ""
say "  Configure a provider and API key interactively:"
say ""
say "    curl -fsSL https://fa1.dev/setup.sh | sh"
say ""
say "  Or set an environment variable manually:"
say ""
say "    export OPENROUTER_API_KEY=<your-key>   # or ANTHROPIC_API_KEY / GOOGLE_API_KEY / OPENAI_API_KEY"
say ""
say "  Then start the agent:"
say ""
say "    fa"
say ""
say "  Or run a single headless task:"
say ""
say "    fa \"summarize CHANGELOG.md\""
say ""
say "  (the legacy command 'fah' also works)"
say ""
say "  Docs:    https://github.com/IstiN/flutter_agent_harness"
say "  Package: https://pub.dev/packages/flutter_agent_harness"
say ""
