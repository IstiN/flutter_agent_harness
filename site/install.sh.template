#!/usr/bin/env bash
# install.sh вҖ” non-interactive one-line installer for the Fa CLI
#              (flutter_agent_harness). Works when piped:
#                curl -fsSL https://fa1.dev/install.sh | sh
#
# What it does:
#   1. Checks that the Dart SDK (`dart`) is on PATH.
#   2. Installs (or updates) `flutter_agent_harness` from pub.dev with a
#      progress bar and step percentages.
#   3. Ensures the pub cache bin directory is on your PATH (auto-adds to the
#      detected shell startup file).
#   4. Prints a concise setup recipe and exits.
#
# For interactive configuration (provider, model, API key), run:
#   curl -fsSL https://fa1.dev/setup.sh | sh
#
# {{GENERATED_HEADER}}

set -euo pipefail

PACKAGE="flutter_agent_harness"
PUB_CACHE_BIN="${PUB_CACHE_BIN:-$HOME/.pub-cache/bin}"

# в”Җв”Җ Output helpers в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
say() {
  printf '%s\n' "$*"
}

info() {
  printf '\033[1;34mвҶ’\033[0m %s\n' "$*"
}

ok() {
  printf '\033[1;32mвң”\033[0m %s\n' "$*"
}

warn() {
  printf '\033[1;33m!\033[0m %s\n' "$*" >&2
}

err() {
  printf '\033[1;31mвңҳ\033[0m %s\n' "$*" >&2
}

progress_bar() {
  local percent="$1" width=30 filled empty i
  filled=$(( percent * width / 100 ))
  empty=$(( width - filled ))
  printf '\r['
  for (( i = 0; i < filled; i++ )); do printf '#'; done
  for (( i = 0; i < empty; i++ )); do printf 'В·'; done
  printf '] %3d%%' "$percent"
}

clear_bar() {
  printf '\r%*s\r' 40 ''
}

# Make `fa`/`fah` usable in the current shell session without reloading.
# When the pub cache bin directory is not on PATH yet (common in curl|sh),
# create symlinks in a directory that is already on PATH so the command
# works immediately without requiring a shell restart.
ensure_fa_in_path() {
  # Already reachable вҖ” nothing to do.
  case ":${PATH}:" in
    *:"$PUB_CACHE_BIN":*) return 0 ;;
  esac

  local candidates=(
    "$HOME/.local/bin"
    "$HOME/bin"
  )
  local dir=""
  for candidate in "${candidates[@]}"; do
    if [[ ":${PATH}:" == *:"$candidate":* ]]; then
      dir="$candidate"
      break
    fi
  done

  # Fallback: prefer ~/.local/bin even if it is not on PATH yet, so the
  # startup-file update we made will pick it up in future sessions.
  if [[ -z $dir ]]; then
    dir="$HOME/.local/bin"
  fi

  if ! mkdir -p "$dir" 2>/dev/null; then
    return 0
  fi

  if [[ ! -w $dir ]]; then
    return 0
  fi

  local linked=0
  for name in fa fah; do
    local target="$PUB_CACHE_BIN/$name"
    local link="$dir/$name"
    if [[ -f $target ]] && ln -sf "$target" "$link" 2>/dev/null; then
      linked=$((linked + 1))
    fi
  done

  if [[ $linked -gt 0 ]]; then
    ok "Created symlinks in $dir so 'fa' is available immediately."
  fi
}

# run_with_progress(cmd, label, start%, end%)
# Runs cmd in the background while animating a progress bar between start/end.
# When cmd finishes, jumps to 100%.
run_with_progress() {
  local cmd="$1" label="$2" start="$3" end="$4"
  local progress=$start step pid

  step=$(( (end - start) * 2 ))  # tenths of a percent per 50ms
  [[ $step -lt 1 ]] && step=1

  info "$label"
  eval "$cmd" &
  pid=$!

  while kill -0 "$pid" 2>/dev/null; do
    progress=$(( progress + step ))
    if [[ $progress -ge $end ]]; then
      progress=$end
      step=0
    fi
    progress_bar "$progress"
    sleep 0.05
  done

  wait "$pid"
  local rc=$?
  progress_bar 100
  printf '\n'
  return $rc
}

# в”Җв”Җ Banner в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
say ""
say "  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—       в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—"
say "  в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—      в•ҡв•җв•җв–Ҳв–Ҳв•”в•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘"
say "  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•”в–Ҳв–Ҳв–Ҳв–Ҳв•”в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в–Ҳв–Ҳв•— в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘"
say "  в–Ҳв–Ҳв•”в•җв•җв•қ  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в•ҡв•җв•җв•җв•җв•қ   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•”в•җв•җв•қ  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘"
say "  в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘         в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘ в•ҡв•җв•қ в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘ в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—"
say "  в•ҡв•җв•қ     в•ҡв•җв•қ  в•ҡв•җв•қ         в•ҡв•җв•қ   в•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•қ     в•ҡв•җв•қв•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қ"
say ""
say "  Fa installer вҖ” flutter_agent_harness CLI"
say ""

# в”Җв”Җ 0. Platform check в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# This script is for Unix-like shells. Native Windows users should use the
# PowerShell installer instead. Git Bash / MSYS / Cygwin can run this script,
# but the PowerShell installer is the recommended Windows path because it
# configures the user PATH and environment variables correctly.
case "${OSTYPE:-}" in
  msys*|cygwin*|mingw*)
    clear_bar
    warn "you appear to be running in a Bash emulation layer on Windows."
    say ""
    say "  For the best Windows experience, use the PowerShell installer:"
    say ""
    say "    irm https://fa1.dev/install.ps1 | iex"
    say ""
    say "  Or install directly with the Dart SDK:"
    say ""
    say "    dart pub global activate flutter_agent_harness"
    say ""
    exit 0
    ;;
esac

# в”Җв”Җ 1. Dart SDK check (0вҖ“15%) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
progress_bar 0
if ! command -v dart >/dev/null 2>&1; then
  clear_bar
  err "the Dart SDK ('dart') is not on your PATH."
  say ""
  say "  Fa is distributed via pub.dev and needs the Dart SDK, bundled with Flutter:"
  say ""
  say "    https://docs.flutter.dev/get-started/install"
  say ""
  say "  Then re-run:"
  say ""
  say "    curl -fsSL https://fa1.dev/install.sh | sh"
  say ""
  exit 1
fi
progress_bar 15

# в”Җв”Җ 2. Activate package from pub.dev (15вҖ“90%) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
clear_bar
if dart pub global list 2>/dev/null | grep -q "^${PACKAGE} "; then
  ACTIVATE_LOG="$(mktemp /tmp/fah-install-XXXXXX)"
  if ! run_with_progress "dart pub global activate ${PACKAGE} >\"${ACTIVATE_LOG}\" 2>&1" "Updating ${PACKAGE} from pub.devвҖҰ" 20 90; then
    err "dart pub global activate failed. Log:"
    cat "${ACTIVATE_LOG}" >&2
    exit 1
  fi
else
  ACTIVATE_LOG="$(mktemp /tmp/fah-install-XXXXXX)"
  if ! run_with_progress "dart pub global activate ${PACKAGE} >\"${ACTIVATE_LOG}\" 2>&1" "Installing ${PACKAGE} from pub.devвҖҰ" 20 90; then
    err "dart pub global activate failed. Log:"
    cat "${ACTIVATE_LOG}" >&2
    exit 1
  fi
fi

# в”Җв”Җ 3. PATH check в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
clear_bar
if command -v fa >/dev/null 2>&1 || command -v fah >/dev/null 2>&1; then
  ok "'fa' is on PATH ($(command -v fa 2>/dev/null || command -v fah))."
else
  warn "'fa' is not on PATH yet. The executables live in ${PUB_CACHE_BIN}"
  say ""

  shell_rc=""
  case "${SHELL:-}" in
    */zsh)  shell_rc="$HOME/.zshrc" ;;
    */bash) shell_rc="$HOME/.bashrc" ;;
    */fish) shell_rc="$HOME/.config/fish/config.fish" ;;
  esac

  if [[ -n $shell_rc ]]; then
    mkdir -p "$(dirname "$shell_rc")"
    # Avoid duplicating the same PATH entry.
    if [[ -f $shell_rc ]] && grep -qF "${PUB_CACHE_BIN}" "$shell_rc" 2>/dev/null; then
      ok "${PUB_CACHE_BIN} is already referenced in ${shell_rc}"
    else
      printf '\n# Fa CLI PATH\nexport PATH="$PATH:%s"\n' "${PUB_CACHE_BIN}" >> "$shell_rc"
      ok "Added ${PUB_CACHE_BIN} to ${shell_rc}"
    fi
    # Try to make the command available in the current session without
    # requiring a shell reload (works when ~/.local/bin or ~/bin is on PATH).
    ensure_fa_in_path
    say ""
    warn "Open a new terminal window/tab, or run this in the current shell:"
    say ""
    printf '    source %s\n' "$shell_rc"
    say ""
    warn "To use 'fa' right now without reloading, run:"
    say ""
    printf '    export PATH="$PATH:%s"\n' "${PUB_CACHE_BIN}"
    say ""
  else
    ensure_fa_in_path
    warn "Add this to your shell startup file (and open a new terminal):"
    say ""
    printf '    export PATH="$PATH:%s"\n' "${PUB_CACHE_BIN}"
    say ""
  fi
fi

# в”Җв”Җ 4. Done в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
say ""
ok "Installation complete."
say ""
say "  Configure a provider and API key interactively:"
say ""
say "    curl -fsSL https://fa1.dev/setup.sh | sh"
say ""
say "  Or set an environment variable manually:"
say ""
say "    export OPENROUTER_API_KEY=<your-key>   # or ANTHROPIC_API_KEY / GOOGLE_API_KEY / OPENAI_API_KEY"
say ""
say "  Then start the agent:"
say ""
say "    fa"
say ""
say "  Or run a single headless task:"
say ""
say "    fa \"summarize CHANGELOG.md\""
say ""
say "  (the legacy command 'fah' also works)"
say ""
say "  Docs:    https://github.com/IstiN/flutter_agent_harness"
say "  Package: https://pub.dev/packages/flutter_agent_harness"
say ""
