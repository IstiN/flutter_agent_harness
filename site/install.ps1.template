# install.ps1 вҖ” non-interactive one-line installer for the Fa CLI on Windows.
#                 Works when piped from PowerShell:
#                   irm https://fa1.dev/install.ps1 | iex
#
# From Windows Command Prompt (cmd.exe) use the wrapper instead:
#   curl -fsSL https://fa1.dev/install.bat -o install.bat && install.bat
#
# What it does:
#   1. Detects OS architecture.
#   2. Downloads the matching Fa binary from the latest GitHub Release.
#   3. Installs it to a directory on the user PATH.
#   4. Prints a concise setup recipe and exits.
#
# Fallback: if the binary is unavailable for this platform, the script falls
# back to `dart pub global activate`, which requires the Dart SDK.
#
# For interactive configuration (provider, model, API key), run:
#   irm https://fa1.dev/setup.ps1 | iex
#
# {{GENERATED_HEADER}}

#Requires -Version 5.1
$ErrorActionPreference = "Stop"

$Repo = "IstiN/flutter_agent_harness"
$BinaryName = "fa"

# в”Җв”Җ Output helpers в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function Write-Info($msg) { Write-Host "вҶ’ $msg" -ForegroundColor Cyan }
function Write-Ok($msg) { Write-Host "вң” $msg" -ForegroundColor Green }
function Write-Warn($msg) { Write-Host "! $msg" -ForegroundColor Yellow }
function Write-Err($msg) { Write-Host "вңҳ $msg" -ForegroundColor Red }

# в”Җв”Җ Banner в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
Write-Host ""
Write-Host "  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—       в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—"
Write-Host "  в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—      в•ҡв•җв•җв–Ҳв–Ҳв•”в•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘"
Write-Host "  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•”в–Ҳв–Ҳв–Ҳв–Ҳв•”в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в–Ҳв–Ҳв•— в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘"
Write-Host "  в–Ҳв–Ҳв•”в•җв•җв•қ  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в•ҡв•җв•җв•җв•җв•қ   в–Ҳв–Ҳв•‘   в•ҡв•җв•җв•җв•җв•қ  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘"
Write-Host "  в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘         в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘ в•ҡв•җв•қ в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘ в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—"
Write-Host "  в•ҡв•җв•қ     в•ҡв•җв•қ  в•ҡв•җв•қ         в•ҡв•җв•қ   в•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•қ     в•ҡв•җв•қв•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қ"
Write-Host ""
Write-Host "  Fa installer вҖ” flutter_agent_harness CLI (Windows)"
Write-Host ""

# в”Җв”Җ 1. Detect platform в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
$arch = if ([Environment]::Is64BitOperatingSystem) { "x64" } else { "ia32" }
# ARM64 Windows detection via processor architecture.
if ($env:PROCESSOR_ARCHITECTURE -eq "ARM64" -or $env:PROCESSOR_ARCHITEW6432 -eq "ARM64") {
    $arch = "arm64"
}
$assetName = "fa-windows-$arch.exe"

# в”Җв”Җ 2. Resolve install directory в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
$installDir = Join-Path $env:LOCALAPPDATA "Fa"
$oldBin = Join-Path $installDir "bin"
# Prefer a directory that is already on PATH.
$userPath = [Environment]::GetEnvironmentVariable("Path", "User")
$pathParts = $userPath -split ';' | ForEach-Object { $_.Trim() } | Where-Object { $_ }
$existingDir = $pathParts | Where-Object { $_ -like "*\Fa\bin" -or $_ -like "*\.local\bin" } | Select-Object -First 1
if ($existingDir) {
    $installDir = Split-Path $existingDir
} elseif ($oldBin -in $pathParts) {
    $installDir = $oldBin
}

if (-not (Test-Path $installDir)) {
    New-Item -ItemType Directory -Force -Path $installDir | Out-Null
}
$target = Join-Path $installDir "$BinaryName.exe"

# в”Җв”Җ 3. Download latest release metadata в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
Write-Info "Resolving latest release..."
try {
    $release = Invoke-RestMethod -Uri "https://api.github.com/repos/$Repo/releases/latest" -UseBasicParsing -MaximumRedirection 5
    $version = $release.tag_name
    $asset = $release.assets | Where-Object { $_.name -eq $assetName } | Select-Object -First 1
} catch {
    $asset = $null
}

# в”Җв”Җ 4. Install binary (or fall back to Dart) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
if ($asset) {
    Write-Info "Downloading Fa $version for windows-$arch..."
    try {
        $progressPreference = 'silentlyContinue'
        Invoke-WebRequest -Uri $asset.browser_download_url -OutFile $target -UseBasicParsing
        $progressPreference = 'Continue'
        Write-Ok "Downloaded $target"
    } catch {
        Write-Err "Failed to download binary: $_"
        exit 1
    }
} else {
    # No binary for this platform вҖ” fall back to Dart-based installation.
    Write-Warn "No prebuilt binary found for windows-$arch. Falling back to Dart pub global activate."
    $dart = Get-Command dart -ErrorAction SilentlyContinue
    if (-not $dart) {
        Write-Err "the Dart SDK ('dart') is not on your PATH, and no prebuilt binary is available for windows-$arch."
        Write-Host ""
        Write-Host "  Install Flutter (includes Dart) from:"
        Write-Host ""
        Write-Host "    https://docs.flutter.dev/get-started/install"
        Write-Host ""
        exit 1
    }
    Write-Info "Activating flutter_agent_harness from pub.dev..."
    & dart pub global activate flutter_agent_harness
    $pubCacheBin = if ($env:PUB_CACHE_BIN) { $env:PUB_CACHE_BIN } else { Join-Path $env:LOCALAPPDATA "Pub\Cache\bin" }
    if (-not (Test-Path $pubCacheBin)) { $pubCacheBin = Join-Path $env:APPDATA "Pub\Cache\bin" }
    $installDir = $pubCacheBin
    $target = Join-Path $installDir "$BinaryName.bat"
}

# в”Җв”Җ 5. Ensure install directory is on the user PATH в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
if ($installDir -notin $pathParts) {
    Write-Info "Adding $installDir to your user PATH"
    $newPath = ($pathParts + $installDir) -join ';'
    [Environment]::SetEnvironmentVariable("Path", $newPath, "User")
}

# Refresh PATH in the current session.
$env:Path = [Environment]::GetEnvironmentVariable("Path", "Machine") + ";" + [Environment]::GetEnvironmentVariable("Path", "User")
$processPaths = $env:Path -split ';' | ForEach-Object { $_.Trim() } | Where-Object { $_ }
if ($installDir -notin $processPaths) {
    $env:Path = ($processPaths + $installDir) -join ';'
}

$faCmd = Get-Command fa -ErrorAction SilentlyContinue
if (-not $faCmd) { $faCmd = Get-Command fah -ErrorAction SilentlyContinue }
if ($faCmd) {
    Write-Ok "'fa' is on PATH ($($faCmd.Source))."
} else {
    Write-Warn "'fa' is not on PATH yet. The executable lives in $installDir"
    Write-Host ""
    Write-Warn "Open a new PowerShell window, or run this in the current one:"
    Write-Host ""
    Write-Host "    `$env:Path = `$env:Path + ';$installDir'"
    Write-Host ""
}

# в”Җв”Җ 6. Done в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
Write-Host ""
Write-Ok "Installation complete."
Write-Host ""
Write-Host "  Configure a provider and API key interactively:"
Write-Host ""
Write-Host "    irm https://fa1.dev/setup.ps1 | iex"
Write-Host ""
Write-Host "  Or set an environment variable manually:"
Write-Host ""
Write-Host "    `$env:OPENROUTER_API_KEY = '<your-key>'   # or ANTHROPIC_API_KEY / GOOGLE_API_KEY / OPENAI_API_KEY"
Write-Host ""
Write-Host "  Then start the agent:"
Write-Host ""
Write-Host "    fa"
Write-Host ""
Write-Host "  Or run a single headless task:"
Write-Host ""
Write-Host "    fa `"summarize CHANGELOG.md`""
Write-Host ""
Write-Host "  (the legacy command 'fah' also works)"
Write-Host ""
Write-Host "  Docs:    https://github.com/IstiN/flutter_agent_harness"
Write-Host "  Package: https://pub.dev/packages/flutter_agent_harness"
Write-Host ""
