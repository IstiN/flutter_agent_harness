#!/usr/bin/env bash
# setup.sh вҖ” interactive configuration wizard for the Fa CLI.
#              Run this after `install.sh` to pick a provider, model, API key,
#              mode and approval policy.
#
#                curl -fsSL "https://fa1.dev/setup.sh" | sh
#
# What it does:
#   1. Verifies `fa` is installed.
#   2. Interactively picks a provider + model (or a custom endpoint).
#   3. Collects the API key and writes ~/.fah/config.yaml.
#   4. Optionally persists the API key in your shell startup file.
#
# {{GENERATED_HEADER}}

set -eu  # no pipefail: dash (Ubuntu sh) lacks it

FAH_CONFIG_DIR="$HOME/.fah"
FAH_CONFIG_FILE="$FAH_CONFIG_DIR/config.yaml"

# в”Җв”Җ TTY handling в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
if [ -t 0 ]; then
  FAH_TTY="/dev/stdin"
else
  FAH_TTY="/dev/tty"
fi

# в”Җв”Җ Output helpers в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
say() {
  printf '%s\n' "$*"
}

info() {
  printf '\033[1;34mвҶ’\033[0m %s\n' "$*"
}

ok() {
  printf '\033[1;32mвң”\033[0m %s\n' "$*"
}

warn() {
  printf '\033[1;33m!\033[0m %s\n' "$*" >&2
}

err() {
  printf '\033[1;31mвңҳ\033[0m %s\n' "$*" >&2
}

# в”Җв”Җ Interactive helpers в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
prompt() {
  local text="$1"
  printf '\033[1m%s\033[0m ' "$text" > /dev/tty
}

ask() {
  local var="$1" text="$2" default="${3:-}"
  while true; do
    if [ -n "$default" ]; then
      prompt "$text [$default]"
    else
      prompt "$text"
    fi
    local value
    if ! read -r value < "$FAH_TTY" 2>/dev/tty; then
      printf -v "$var" '%s' "$default"
      return 1
    fi
    if [ -z "$value" ] && [ -n "$default" ]; then
      value=$default
    fi
    printf -v "$var" '%s' "$value"
    return 0
  done
}

ask_hidden() {
  local var="$1" text="$2"
  prompt "$text"
  local value
  if ! read -rs value < "$FAH_TTY" 2>/dev/tty; then
    printf -v "$var" ''
    return 1
  fi
  printf '\n' > /dev/tty
  printf -v "$var" '%s' "$value"
  return 0
}

ask_yn() {
  local var="$1" text="$2" default="${3:-y}"
  local answer
  while true; do
    if [ "$default" = "y" ]; then
      prompt "$text [Y/n]"
    else
      prompt "$text [y/N]"
    fi
    if ! read -r answer < "$FAH_TTY" 2>/dev/tty; then
      printf -v "$var" '%s' "$default"
      return 1
    fi
    answer=${answer:-$default}
    case "$answer" in
      [Yy]|"" ) printf -v "$var" 'y'; return 0 ;;
      [Nn]    ) printf -v "$var" 'n'; return 0 ;;
    esac
    warn "please answer y or n"
  done
}

# в”Җв”Җ Banner в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
say ""
say "  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—       в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—"
say "  в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—      в•ҡв•җв•җв–Ҳв–Ҳв•”в•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘"
say "  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•”в–Ҳв–Ҳв–Ҳв–Ҳв•”в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в–Ҳв–Ҳв•— в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘"
say "  в–Ҳв–Ҳв•”в•җв•җв•қ  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в•ҡв•җв•җв•җв•җв•қ   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•”в•җв•җв•қ  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘"
say "  в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘         в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘ в•ҡв•җв•қ в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘ в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—"
say "  в•ҡв•җв•қ     в•ҡв•җв•қ  в•ҡв•җв•қ         в•ҡв•җв•қ   в•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•қ     в•ҡв•җв•қв•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қ"
say ""
say "  Fa setup wizard вҖ” flutter_agent_harness CLI"
say ""

# в”Җв”Җ 1. Verify CLI is installed в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
if ! command -v fa >/dev/null 2>&1 && ! command -v fah >/dev/null 2>&1; then
  err "'fa' is not on your PATH."
  say ""
  say "  Run the installer first:"
  say ""
  say "    curl -fsSL \"https://fa1.dev/install.sh\" | sh"
  say ""
  say "  Then reload your shell (or open a new terminal) and run this wizard again:"
  say ""
  say "    curl -fsSL \"https://fa1.dev/setup.sh\" | sh"
  say ""
  exit 1
fi
ok "Found 'fa' on PATH ($(command -v fa 2>/dev/null || command -v fah))."

# в”Җв”Җ 2. Interactive configuration в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
if [ ! -e /dev/tty ] || [ ! -t 2 ]; then
  info "Non-interactive environment detected."
  say ""
  say "  To finish setup, set an API key and run:"
  say ""
  say "    fa"
  say ""
  exit 0
fi

if [ -f "$FAH_CONFIG_FILE" ]; then
  reconfigure="n"
  ask_yn reconfigure "A config already exists at ${FAH_CONFIG_FILE}. Reconfigure?" "n"
  if [ "$reconfigure" != "y" ]; then
    ok "Kept existing config. Run 'fa' to start."
    exit 0
  fi
fi

say ""
info "Let's configure your default provider and model."
say ""

{{PROVIDER_MENU}}

{{PROVIDER_CASES}}

# API key
say ""
api_key=""
if [ "$provider" = "custom" ]; then
  ask_yn needs_key "Does this endpoint require an API key?" "n"
  if [ "$needs_key" = "y" ]; then
    ask_hidden api_key "Paste your API key"
  fi
else
  ask_hidden api_key "Paste your ${key_var}"
fi

{{MODE_MENU}}

{{MODE_CASES}}

{{APPROVAL_MENU}}

{{APPROVAL_CASES}}

# Write config.yaml
mkdir -p "$FAH_CONFIG_DIR"
cat > "$FAH_CONFIG_FILE" <<EOF
provider: ${provider_kind}
model: ${model}
baseUrl: ${base_url}
mode: ${mode}
approvalMode: ${approval}
allowedTools: []
EOF
ok "Wrote ${FAH_CONFIG_FILE}"

# Persist API key in shell startup file
if [ -n "$api_key" ]; then
  say ""
  shell_rc=""
  case "${SHELL:-}" in
    */zsh)  shell_rc="$HOME/.zshrc" ;;
    */bash) shell_rc="$HOME/.bashrc" ;;
    */fish) shell_rc="$HOME/.config/fish/config.fish" ;;
  esac

  if [ -n "$shell_rc" ]; then
    persist="n"
    ask_yn persist "Add ${key_var} to ${shell_rc}? (we never log the value)" "y"
    if [ "$persist" = "y" ]; then
      if [ -f "$shell_rc" ] && grep -qF "export ${key_var}=" "$shell_rc" 2>/dev/null; then
        sed -i.bak "s|^export ${key_var}=.*|export ${key_var}='${api_key}'|" "$shell_rc" && rm -f "${shell_rc}.bak"
      else
        printf "\n# Fa CLI API key\nexport %s='%s'\n" "$key_var" "$api_key" >> "$shell_rc"
      fi
      ok "Saved ${key_var} to ${shell_rc}"
      ok "Reload your shell or run: source ${shell_rc}"
    else
      say ""
      say "  Add this to your environment manually:"
      say ""
      say "    export ${key_var}=<your-key>"
      say ""
    fi
  else
    say ""
    say "  Add this to your environment manually:"
    say ""
    say "    export ${key_var}=<your-key>"
    say ""
  fi
fi

# в”Җв”Җ 3. Done в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
say ""
ok "Configuration complete."
say ""
say "  Start the agent:"
say ""
say "    fa"
say ""
say "  Or run a single headless task:"
say ""
say "    fa \"summarize CHANGELOG.md\""
say ""
say "  (the legacy command 'fah' also works)"
say ""
