#!/usr/bin/env bash
# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  QUALITY GATE — DO NOT LOWER THESE THRESHOLDS WITHOUT TEAM APPROVAL       ║
# ║  Every commit must pass: file size, analyze, tests, coverage ≥ 80%,       ║
# ║  duplication < 1%.                                                        ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
#
# Pre-commit hook for flutter_agent_harness (pure Dart package).
# Canonical copy: scripts/pre-commit — install with:
#   cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# To skip (emergency only): git commit --no-verify

set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

# Unset git env vars so test processes that spawn git subprocesses use the
# correct working directory rather than the hook's environment.
unset GIT_DIR GIT_INDEX_FILE GIT_WORK_TREE 2>/dev/null || true

COVERAGE_BASELINE=80.0
DUP_THRESHOLD=1.0
MAX_LINES=2800

# ═══════════════════════════════════════════════════════════════════════════
# 1. FILE SIZE GUARD
# ═══════════════════════════════════════════════════════════════════════════
VIOLATIONS=()
while IFS= read -r file; do
  case "$file" in
    *.dart)
      case "$file" in
        *.g.dart|*.freezed.dart|*.mocks.dart|*bridge_generated*.dart) continue ;;
      esac
      lines=$(wc -l < "$file")
      if (( lines > MAX_LINES )); then
        VIOLATIONS+=("  $file: $lines lines (max $MAX_LINES)")
      fi
      ;;
  esac
done < <(git diff --cached --name-only --diff-filter=ACM)

if ((${#VIOLATIONS[@]} > 0)); then
  echo ""
  echo "╔═══════════════════════════════════════════════════════════════════════════╗"
  echo "║  ❌ QUALITY GATE FAILED — FILE SIZE                                       ║"
  echo "╚═══════════════════════════════════════════════════════════════════════════╝"
  printf '%s\n' "${VIOLATIONS[@]}"
  exit 1
fi

# ═══════════════════════════════════════════════════════════════════════════
# 2. STATIC ANALYSIS
# ═══════════════════════════════════════════════════════════════════════════
echo "🔍 Running dart analyze..."
dart analyze

echo "🔍 Checking dart format..."
dart format --output=none --set-exit-if-changed .

# ═══════════════════════════════════════════════════════════════════════════
# 3. TESTS WITH COVERAGE
# ═══════════════════════════════════════════════════════════════════════════
# Integration tests call external LLM endpoints and are too slow/non-deterministic
# for a pre-commit gate; they run in CI / manually instead.
echo "🧪 Running dart test --coverage (excluding integration tests)..."
rm -rf coverage
dart test --coverage=coverage --exclude-tags integration

echo "📊 Formatting coverage to lcov..."
dart run coverage:format_coverage --lcov -i coverage -o coverage/lcov.info

# ═══════════════════════════════════════════════════════════════════════════
# 4. COVERAGE RATCHET (lib/ only)
# ═══════════════════════════════════════════════════════════════════════════
echo "🔍 Checking line coverage (baseline: >= ${COVERAGE_BASELINE}%)..."
if python3 scripts/check_coverage.py "$COVERAGE_BASELINE"; then
  echo "✅ Coverage gate OK"
else
  echo ""
  echo "╔═══════════════════════════════════════════════════════════════════════════╗"
  echo "║  ❌ QUALITY GATE FAILED — TEST COVERAGE                                   ║"
  echo "╚═══════════════════════════════════════════════════════════════════════════╝"
  echo "   Add tests for uncovered code, then retry."
  exit 1
fi

# ═══════════════════════════════════════════════════════════════════════════
# 5. CODE DUPLICATION GUARD
# ═══════════════════════════════════════════════════════════════════════════
if command -v jscpd >/dev/null 2>&1; then
  echo "🔍 Checking code duplication (threshold: < ${DUP_THRESHOLD}%)..."
  jscpd --min-tokens 50 --min-lines 5 --reporters json --output /tmp/jscpd-precommit lib/ >/dev/null 2>&1 || true
  DUP_PCT=$(python3 -c "
import json
try:
    with open('/tmp/jscpd-precommit/jscpd-report.json') as f:
        d=json.load(f)
    print(d['statistics']['total']['percentage'])
except Exception:
    print('0.0')
" 2>/dev/null || echo "0.0")
  if python3 -c "exit(0 if float('$DUP_PCT') < float('$DUP_THRESHOLD') else 1)"; then
    echo "✅ Duplication check OK ($DUP_PCT% < ${DUP_THRESHOLD}%)"
  else
    echo ""
    echo "╔═══════════════════════════════════════════════════════════════════════════╗"
    echo "║  ❌ QUALITY GATE FAILED — CODE DUPLICATION                                ║"
    echo "╚═══════════════════════════════════════════════════════════════════════════╝"
    echo "   Duplication: $DUP_PCT% (max ${DUP_THRESHOLD}%)"
    echo "   Run: jscpd --min-tokens 50 --min-lines 5 lib/"
    exit 1
  fi
else
  echo "⚠️  jscpd not found, skipping duplication check (npm install -g jscpd)"
fi

echo ""
echo "╔═══════════════════════════════════════════════════════════════════════════╗"
echo "║  ✅ ALL QUALITY GATES PASSED — COMMIT APPROVED                            ║"
echo "╚═══════════════════════════════════════════════════════════════════════════╝"
