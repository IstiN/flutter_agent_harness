# Dart / Flutter
.dart_tool/
build/
coverage/
# The Pages workflow assembles the Flutter web demo here; never commit it.
site/app/
# library package: lockfile is not committed
pubspec.lock
*.iml
.idea/
.vscode/
.DS_Store
.repro/

# Vendor dependencies (local wasm_run fork) - keep source, ignore build artifacts
vendor/**/target/
vendor/**/build/
vendor/**/.dart_tool/
# The prebuilt iOS framework is downloaded from pub cache by scripts/setup_vendor_ios.sh
vendor/wasm_run_flutter/ios/Frameworks/WasmRun.xcframework/
# The prebuilt macOS framework is downloaded on first build by wasm_run_flutter.
vendor/wasm_run_flutter/macos/Frameworks/

# Environment secrets
.env
.env.*
!.env.example
!.env.sample

# Firebase configuration files (contain API keys and project IDs).
# Populate from your own Firebase project download; never commit.
google-services.json
GoogleService-Info.plist
# firebase_options.dart is checked in for CI builds (public API keys only).

